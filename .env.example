# Copy to .env for local dev (`vercel dev`) and set the same keys in
# Vercel → Project → Settings → Environment Variables for production.
# Never commit the real .env — it is gitignored.

# ── Firebase Admin (Firestore) — server-only ──
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Paste the whole key on ONE line, keeping the literal \n sequences, wrapped in quotes:
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ── Resend (email notifications to Khalif) ──
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM="Khalif Rooble <hello@yourdomain.com>"
NOTIFY_EMAIL=khalif@yourdomain.com

# ── Gemini (AI assistant) ──
GEMINI_API_KEY=AIzaSy...
# Optional — defaults to gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
